{
  "crons": [
    {
      "path": "/api/v1/cron/relatorio-diario",
      "schedule": "0 0 * * 2-6"
    },
    {
      "path": "/api/v1/cron/relatorio-semanal",
      "schedule": "0 10 * * 1"
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Admin-Token, X-Cron-Secret" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
